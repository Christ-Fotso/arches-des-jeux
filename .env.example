# ===========================================
# BEAUTYSHOP - Environment Variables
# ===========================================
# IMPORTANT: Ne JAMAIS commiter ce fichier avec de vraies valeurs!
# Copier ce fichier vers .env et remplir avec vos vraies valeurs

# ===========================================
# DATABASE CONFIGURATION
# ===========================================
POSTGRES_USER=beaute
POSTGRES_PASSWORD=GENERATE_WITH_openssl_rand_base64_32
POSTGRES_DB=beaute_suisse

# Database URL pour l'application
# Format: postgresql://user:password@host:port/database
# En développement local:
DATABASE_URL=postgresql://beaute:VOTRE_MOT_DE_PASSE@localhost:5432/beaute_suisse
# En production avec Docker:
# DATABASE_URL=postgresql://beaute:VOTRE_MOT_DE_PASSE@postgres:5432/beaute_suisse

# ===========================================
# JWT AUTHENTICATION
# ===========================================
# Générer avec: openssl rand -hex 32
JWT_SECRET=GENERATE_WITH_openssl_rand_hex_32

# ===========================================
# STRIPE PAYMENT
# ===========================================
# Clés de test Stripe (commencent par sk_test_ et pk_test_)
# Obtenir sur: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_VOTRE_CLE_SECRETE_STRIPE
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_VOTRE_CLE_PUBLIQUE_STRIPE

# ===========================================
# SHIPPO SHIPPING
# ===========================================
# Clé API Shippo pour le calcul des frais de livraison
# Obtenir sur: https://goshippo.com
SHIPPO_PRIVATE_KEY=shippo_test_VOTRE_CLE_SHIPPO

# ===========================================
# EMAIL CONFIGURATION
# ===========================================
# Configuration SMTP pour l'envoi d'emails
# Gmail: smtp.gmail.com (port 587)
# Yahoo: smtp.mail.yahoo.com (port 587)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=votre-email@gmail.com
EMAIL_PASSWORD=votre-mot-de-passe-application
EMAIL_FROM=BeautyShop <noreply@beautyshop.com>

# ===========================================
# APPLICATION
# ===========================================
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:5173

# ===========================================
# GÉNÉRATION DES SECRETS
# ===========================================
# 1. JWT Secret:
#    openssl rand -hex 32
#
# 2. Database Password:
#    openssl rand -base64 32
#
# 3. Stripe Keys:
#    Obtenir depuis https://dashboard.stripe.com/test/apikeys
#
# 4. Email Password (Gmail):
#    Créer un mot de passe d'application dans les paramètres Google
#    https://myaccount.google.com/apppasswords
#
# ===========================================
# SÉCURITÉ
# ===========================================
# - Ne JAMAIS commiter le fichier .env
# - Utiliser des secrets différents pour dev/staging/prod
# - Régénérer tous les secrets régulièrement
# - En production, utiliser un gestionnaire de secrets
#   (AWS Secrets Manager, Azure Key Vault, etc.)
